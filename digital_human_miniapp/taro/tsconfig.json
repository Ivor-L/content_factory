{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": false,
    "jsx": "react-jsx",
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@tarojs/taro", "webpack-env"],
    "lib": ["ES2020", "DOM"]
  },
  "include": ["src/**/*", "config/**/*"]
}
