model Character {
  id                   String                @id @default(cuid())
  name                 String
  avatar               String
  voiceId              String?               @map("voice_id")
  userId               String?               @map("user_id") @db.Uuid
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  storyboardTasks      StoryboardTask[]
  replicationShotTasks ReplicationShotTask[]

  @@map("characters")
  @@schema("public")
}

model Product {
  id                   String                @id @default(cuid())
  name                 String
  description          String
  sellingPoints        String                @map("selling_points")
  sellingPointsText    String?               @map("selling_points_text")
  images               String
  analysisResult       String?               @map("analysis_result")
  status               String                @default("PENDING")
  progress             Int                   @default(0)
  userId               String?               @map("user_id") @db.Uuid
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  replications         Replication[]
  storyboardTasks      StoryboardTask[]
  replicationShotTasks ReplicationShotTask[]

  @@map("products")
  @@schema("public")
}

model CanvasProject {
  id         String   @id @default(cuid())
  userId     String   @map("user_id") @db.Uuid
  name       String   @default("")
  thumbnail  String?  @db.Text
  canvasData Json?    @map("canvas_data")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "canvas_projects_user_id_idx")
  @@map("canvas_projects")
  @@schema("public")
}

model Replication {
  id          String   @id @default(cuid())
  status      String
  result      String
  type        String   @default("FULL")
  productId   String?  @map("product_id")
  scriptId    String?  @map("script_id")
  inputParams Json?    @default("{}") @map("input_params")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  product     Product? @relation(fields: [productId], references: [id])
  script      Script?  @relation(fields: [scriptId], references: [id])

  @@map("replications")
  @@schema("public")
}

model Script {
  id                   String                @id @default(cuid())
  title                String
  videoUrl             String                @map("video_url")
  breakdown            String
  blueprint            String?               @db.Text // New field for JSON analysis result
  status               String                @default("PENDING")
  progress             Int                   @default(0)
  error                String? // New field for error messages
  userId               String?               @map("user_id") @db.Uuid
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  replications         Replication[]
  replicationShotTasks ReplicationShotTask[]

  @@map("scripts")
  @@schema("public")
}

