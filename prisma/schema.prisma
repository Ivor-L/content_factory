  // Source post data
  sourceTitle     String?      @map("source_title")
  sourceText      String?      @map("source_text") @db.Text
  sourceImages    Json?        @map("source_images") // string[]
  sourcePlatform  String?      @map("source_platform")
  sourceId        String?      @map("source_id")
  sourceUrl       String?      @map("source_url")
  // Analysis result written back by n8n webhook
  analysisResult  Json?        @map("analysis_result")
  // Selected style (null = replicate original style)
  stylePresetId   String?      @map("style_preset_id") @db.Uuid
  stylePreset     StylePreset? @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)
  // Optional topic/keyword hint provided by user
  topicHint       String?      @map("topic_hint")
  // Generated content written back by n8n webhook
  generatedCopy   String?      @map("generated_copy") @db.Text
  generatedImages Json?        @map("generated_images") // string[] — Supabase storage URLs
  imageGuidance   Json?        @map("image_guidance") // [{index, description}]
  errorMessage    String?      @map("error_message")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([userId, updatedAt(sort: Desc)])
  @@map("image_text_replication_tasks")
  @@schema("public")
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String   @map("user_id") @db.Uuid
  label        String?
  keyHash      String   @map("key_hash")
  lastFour     String   @map("last_four") @db.VarChar(8)
  status       String   @default("active")
  scopes       String[] @default([])
  quotaCredits Int?     @map("quota_credits")
  agentId      String?  @map("agent_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([keyHash], map: "api_keys_key_hash_unique")
  @@index([userId], map: "api_keys_user_id_idx")
  @@index([status], map: "api_keys_status_idx")
  @@map("api_keys")
  @@schema("public")
}

model Wallet {
  userId         String   @id @map("user_id") @db.Uuid
  balanceCredits BigInt   @default(0) @map("balance_credits")
  currency       String   @default("CNY")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("wallets")
  @@schema("public")
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String   @map("user_id") @db.Uuid
  type          String
  amountCredits BigInt   @map("amount_credits")
  amountCny     Decimal? @map("amount_cny") @db.Decimal(12, 2)
  channel       String?
  refId         String?  @map("ref_id")
  meta          Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt], map: "transactions_user_created_idx")
  @@map("transactions")
  @@schema("public")
}

model UsageLog {
  id               String   @id @default(cuid())
  userId           String   @map("user_id") @db.Uuid
  apiKeyId         String?  @map("api_key_id")
  modelId          String   @map("model_id")
  route            String
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  priceCny         Decimal  @map("price_cny") @db.Decimal(12, 4)
  chargedCredits   BigInt   @map("charged_credits")
  responseMs       Int?     @map("response_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt], map: "usage_logs_user_created_idx")
  @@index([modelId], map: "usage_logs_model_idx")
  @@map("usage_logs")
  @@schema("public")
}

model ModelPrice {
  modelId           String   @id @map("model_id")
  displayName       String   @map("display_name")
  provider          String
  type              String
  baseCostCnyPer1K  Decimal  @map("base_cost_cny_per_1k") @db.Decimal(12, 4)
  sellPriceCnyPer1K Decimal  @map("sell_price_cny_per_1k") @db.Decimal(12, 4)
  minIncrement      Int      @map("min_increment")
  routes            String[] @default([])
  capabilities      String[] @default([])
  description       String?
  docsLink          String?  @map("docs_link")
  status            String   @default("active")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("model_prices")
  @@schema("public")
}

model RechargeOrder {
  id            String   @id @default(cuid())
  userId        String   @map("user_id") @db.Uuid
  amountCny     Decimal  @map("amount_cny") @db.Decimal(12, 2)
  credits       BigInt
  status        String   @default("pending")
  alipayTradeNo String?  @map("alipay_trade_no")
  payUrl        String?  @map("pay_url")
  meta          Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt], map: "recharge_orders_user_created_idx")
  @@map("recharge_orders")
  @@schema("public")
}

model AgentRelation {
  id             String   @id @default(cuid())
  parentUserId   String   @map("parent_user_id") @db.Uuid
  childUserId    String   @map("child_user_id") @db.Uuid
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 4)
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([parentUserId, childUserId], map: "agent_relations_unique_pair")
  @@map("agent_relations")
  @@schema("public")
}

model CanvasPreset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  name      String
  nodes     Json
  resources Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "canvas_presets_user_id_idx")
  @@map("canvas_presets")
  @@schema("public")
}

model CanvasGridSplitResult {
  id        String   @id @default(cuid())
  taskId    String   @unique @map("task_id")
  nodeId    String   @map("node_id")
  status    String
  imageUrls String[] @default([]) @map("image_urls")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("canvas_grid_split_results")
  @@schema("public")
}

model KnowledgeFolder {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  files       KnowledgeFile[]
  chunks      KnowledgeChunk[]
  conversations AssistantConversation[]

  @@index([userId, updatedAt(sort: Desc)], map: "knowledge_folders_user_updated_idx")
  @@map("knowledge_folders")
  @@schema("public")
}

model KnowledgeFile {
  id           String           @id @default(uuid()) @db.Uuid
  folderId     String           @map("folder_id") @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  title        String
  sourceType   String?          @map("source_type")
  status       String           @default("READY")
  originalPath String           @map("original_path")
  metadata     Json?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  folder       KnowledgeFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  chunks       KnowledgeChunk[]

  @@index([folderId, createdAt(sort: Desc)], map: "knowledge_files_folder_created_idx")
  @@index([userId, createdAt(sort: Desc)], map: "knowledge_files_user_created_idx")
  @@map("knowledge_files")
  @@schema("public")
}

model KnowledgeChunk {
  id            String          @id @default(uuid()) @db.Uuid
  folderId      String          @map("folder_id") @db.Uuid
  fileId        String          @map("file_id") @db.Uuid
  chunkIndex    Int             @map("chunk_index")
  content       String          @db.Text
  contentLength Int             @default(0) @map("content_length")
  metadata      Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  folder        KnowledgeFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  file          KnowledgeFile   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([folderId, createdAt(sort: Desc)], map: "knowledge_chunks_folder_created_idx")
  @@index([fileId, chunkIndex], map: "knowledge_chunks_file_chunk_idx")
  @@map("knowledge_chunks")
  @@schema("public")
}

model AssistantConversation {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  title         String?
  assistantMode String             @default("xhs") @map("assistant_mode")
  folderId      String?            @map("folder_id") @db.Uuid
  model         String?
  skills        String[]           @default([])
  metadata      Json?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  lastMessageAt DateTime           @default(now()) @map("last_message_at")
  folder        KnowledgeFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messages      AssistantMessage[]

  @@index([userId, lastMessageAt(sort: Desc)], map: "assistant_conversations_user_last_message_idx")
  @@index([folderId], map: "assistant_conversations_folder_idx")
  @@map("assistant_conversations")
  @@schema("public")
}

model AssistantMessage {
  id             String                 @id @default(uuid()) @db.Uuid
  conversationId String                 @map("conversation_id") @db.Uuid
  role           String
  content        String                 @db.Text
  metadata       Json?
  createdAt      DateTime               @default(now()) @map("created_at")
  conversation   AssistantConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt], map: "assistant_messages_conversation_created_idx")
  @@map("assistant_messages")
  @@schema("public")
}
