    {
      "parameters": {
        "jsCode": "/**\n * n8n Code \u8282\u70b9\uff1a\u628a\u4e0b\u8f7d\u597d\u7684\u89c6\u9891\uff08\u4e8c\u8fdb\u5236\uff09\u5582\u7ed9 Yunwu Gemini generateContent\n * \u8f93\u51fa\uff1a{ gemini_body }\n */\n\nfunction pickBinaryKey(bin) {\n  if (!bin || typeof bin !== \"object\") return \"\";\n  if (bin.video) return \"video\";\n  if (bin.data) return \"data\";\n  const keys = Object.keys(bin);\n  return keys.length ? keys[0] : \"\";\n}\n\nfunction ensureBase64FromBinary(itemIndex, binaryKey) {\n  const bin = $input.all()[itemIndex].binary?.[binaryKey];\n  if (!bin) throw new Error(`Binary key \\\"${binaryKey}\\\" not found`);\n  if (bin.data && typeof bin.data === \"string\" && bin.data.length > 50) {\n    return bin.data;\n  }\n  return null;\n}\n\nconst systemText = `# Role\n\u4f60\u662f\u4e00\u4f4d\u7cbe\u901a**\u89c6\u9891\u9006\u5411\u5de5\u7a0b**\u4e0e**\u5546\u4e1a\u53d9\u4e8b\u903b\u8f91\u62c6\u89e3**\u7684\u4e13\u5bb6\u3002\u4f60\u7684\u6838\u5fc3\u80fd\u529b\u662f\u900f\u8fc7\u50cf\u7d20\u8868\u8c61\uff0c\u63d0\u53d6\u89c6\u9891\u7684\u201c\u7206\u6b3e\u57fa\u56e0\u201d\u3002\n\n# Goal\n\u8f93\u51fa\u4e00\u4efd\u6807\u51c6\u7684 JSON \u683c\u5f0f\u5206\u6790\u62a5\u544a\u3002\u8fd9\u4efd\u62a5\u544a\u5c06\u4f5c\u4e3a\u201c\u6bcd\u7248\u201d\uff0c\u6307\u5bfc\u4e0b\u6e38 AI \u5728\u4fdd\u7559\u539f\u89c6\u9891\u8fd0\u955c\u3001\u8282\u594f\u548c\u60c5\u7eea\u903b\u8f91\u7684\u524d\u63d0\u4e0b\uff0c\u586b\u5165\u5168\u65b0\u7684\u4ea7\u54c1\u751f\u6210\u65b0\u89c6\u9891\u3002\n\n# Output Format (JSON Schema)\n\u8bf7\u4e25\u683c\u9075\u5b88\u4ee5\u4e0b JSON \u7ed3\u6784\u8f93\u51fa\uff0c\u4e0d\u8981\u5305\u542b\u4efb\u4f55 Markdown \u4ee3\u7801\u5757\u4ee5\u5916\u7684\u95f2\u804a\uff1a\n\\`\\`\\`json\n{\n  \\\"meta\\\": {\n    \\\"art_style\\\": \\\"\u5168\u5c40\u827a\u672f\u98ce\u683c\\\",\n    \\\"render_quality\\\": \\\"\u6e32\u67d3\u8d28\u91cf\\\",\n    \\\"mood_atmosphere\\\": \\\"\u6838\u5fc3\u60c5\u7eea\u6c1b\u56f4\\\",\n    \\\"total_duration\\\": \\\"\u89c6\u9891\u603b\u65f6\u957f\\\"\n  },\n  \\\"scene_breakdown\\\": [\n    {\n      \\\"id\\\": 1,\n      \\\"time_range\\\": \\\"00:00 - 00:XX\\\",\n      \\\"visual_specs\\\": {\n        \\\"camera\\\": \\\"\u955c\u5934\u4fe1\u606f\\\",\n        \\\"subject_action\\\": \\\"\u4e3b\u4f53\u52a8\u4f5c\\\",\n        \\\"lighting_environment\\\": \\\"\u73af\u5883\u7ec6\u8282\\\",\n        \\\"auxiliary_elements\\\": \\\"\u8f85\u52a9\u5143\u7d20\\\"\n      },\n      \\\"abstract_logic\\\": {\n        \\\"narrative_role\\\": \\\"\u53d9\u4e8b\u529f\u80fd\\\",\n        \\\"universal_instruction\\\": \\\"\u901a\u7528\u751f\u6210\u6307\u4ee4\uff0c\u5305\u542b[HERO_PRODUCT]\u53d8\u91cf\\\"\n      }\n    }\n  ]\n}\n\\`\\`\\`\n`;\n\nconst items = $input.all();\nconst out = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  const bin = item.binary || {};\n  const binaryKey = pickBinaryKey(bin);\n  if (!binaryKey) {\n    throw new Error(\"No binary data found. Make sure the download node outputs binary (e.g., data/video).\");\n  }\n\n  const mimeType = bin[binaryKey]?.mimeType || \"video/mp4\";\n\n  let base64 = ensureBase64FromBinary(i, binaryKey);\n  if (!base64) {\n    if (!this?.helpers?.getBinaryDataBuffer) {\n      throw new Error(\n        `Binary has no .data and this.helpers.getBinaryDataBuffer is unavailable.`\n      );\n    }\n    const buf = await this.helpers.getBinaryDataBuffer(i, binaryKey);\n    base64 = buf.toString(\"base64\");\n  }\n\n  const gemini_body = {\n    systemInstruction: { parts: [{ text: systemText }] },\n    contents: [\n      {\n        role: \"user\",\n        parts: [\n          {\n            inlineData: {\n              mimeType,\n              data: base64\n            }\n          }\n        ]\n      }\n    ],\n    generationConfig: {\n      responseMimeType: \"application/json\"\n    }\n  };\n\n  out.push({\n    json: {\n      ...item.json,\n      script_id: $('Webhook').item.json.body.script_id,\n      video_url: $('Webhook').item.json.body.video_url,\n      api_key: $('Webhook').item.json.body.api_key,\n      workflow_id: $('Webhook').item.json.body.workflow_id,\n      gemini_body,\n      _debug_binary: {\n        binaryKey,\n        mimeType,\n        base64_length: base64.length\n      }\n    },\n    binary: item.binary\n  });\n}\n\nreturn out;\n"
      },
