    {
      "parameters": {
        "jsCode": "function pickBinaryKey(bin) {\n  if (!bin || typeof bin !== 'object') return '';\n  if (bin.video) return 'video';\n  if (bin.data) return 'data';\n  const keys = Object.keys(bin);\n  return keys.length ? keys[0] : '';\n}\n\nasync function getBase64(itemIndex, binaryKey) {\n  const item = $input.all()[itemIndex];\n  const bin = item.binary?.[binaryKey];\n  if (!bin) return null;\n  if (bin.data && typeof bin.data === 'string' && bin.data.length > 20) {\n    return bin.data;\n  }\n  if (this?.helpers?.getBinaryDataBuffer) {\n    const buf = await this.helpers.getBinaryDataBuffer(itemIndex, binaryKey);\n    return buf.toString('base64');\n  }\n  return null;\n}\n\nconst DEFAULT_EXTRACT_SYSTEM_PROMPT = `# Role\n你是一位精通视频逆向工程与商业叙事逻辑拆解的专家。你的核心能力是透过像素表象，提取视频的\"爆款基因\"，同时精准还原视频中的口播文案。\n\n# Goal\n输出一份标准 JSON 分析报告，包含两部分：\n1. 视觉蓝图（blueprint 部分）：保留原视频运镜、节奏和情绪逻辑，作为\"母版\"供下游AI填入新产品\n2. 口播文案（breakdown 部分）：提取视频中的口播/旁白内容，结构化为三段式\n\n# Output Format\n请严格输出 JSON，不要输出 Markdown，不要闲聊：\n{\n  \"meta\": {\n    \"art_style\": \"全局艺术风格\",\n    \"render_quality\": \"渲染质量\",\n    \"mood_atmosphere\": \"核心情绪氛围\",\n    \"total_duration\": \"视频总时长\"\n  },\n  \"scene_breakdown\": [\n    {\n      \"id\": 1,\n      \"time_range\": \"00:00 - 00:XX\",\n      \"visual_specs\": {\n        \"camera\": \"镜头信息\",\n        \"subject_action\": \"主体动作\",\n        \"lighting_environment\": \"环境细节\",\n        \"auxiliary_elements\": \"辅助元素\"\n      },\n      \"abstract_logic\": {\n        \"narrative_role\": \"叙事功能\",\n        \"universal_instruction\": \"通用生成指令，包含[HERO_PRODUCT]变量\"\n      }\n    }\n  ],\n  \"breakdown\": {\n    \"description\": \"视频整体背景描述，包含产品类别、目标受众、核心卖点概述\",\n    \"intro\": \"钩子与开场白：视频前段的口播内容，原文还原或高度概括\",\n    \"body\": \"核心价值与产品讲解：视频中段的口播内容，包含卖点、使用场景、用户痛点\",\n    \"conclusion\": \"行动号召与结尾：视频结尾的口播内容，包含促销信息、CTA指令\"\n  }\n}`;\n\nconst items = $input.all();\nconst out = [];\nconst webhookBody = $('Webhook').item.json.body || {};\nconst promptOverrides = (webhookBody.prompt_overrides && typeof webhookBody.prompt_overrides === 'object')\n  ? webhookBody.prompt_overrides\n  : {};\n\nconst systemText = String(\n  promptOverrides.extract_system ??\n  webhookBody.extract_system_prompt ??\n  DEFAULT_EXTRACT_SYSTEM_PROMPT\n).trim();\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  const err = item.json?.error;\n  const bin = item.binary || {};\n  const binaryKey = pickBinaryKey(bin);\n\n  let download_ok = false;\n  let final_status = null;\n  let final_error = null;\n  let gemini_body = null;\n  let mimeType = null;\n  let base64 = null;\n\n  if (err) {\n    final_status = 'failed';\n    final_error = `下载视频失败: ${err.message || JSON.stringify(err)}`;\n  } else if (!binaryKey) {\n    final_status = 'failed';\n    final_error = '下载视频失败：未拿到binary数据';\n  } else {\n    mimeType = bin[binaryKey]?.mimeType || 'video/mp4';\n    base64 = await getBase64.call(this, i, binaryKey);\n    if (!base64) {\n      final_status = 'failed';\n      final_error = '视频binary转base64失败';\n    } else {\n      download_ok = true;\n      gemini_body = {\n        systemInstruction: { parts: [{ text: systemText }] },\n        contents: [{ role: 'user', parts: [{ inlineData: { mimeType, data: base64 } }] }],\n        generationConfig: { responseMimeType: 'application/json' }\n      };\n    }\n  }\n\n  out.push({\n    json: {\n      script_id: webhookBody.script_id,\n      video_url: webhookBody.video_url,\n      api_key: webhookBody.api_key,\n      workflow_id: webhookBody.workflow_id,\n      download_ok,\n      final_status,\n      final_error,\n      gemini_body,\n      _debug_binary: {\n        binaryKey: binaryKey || null,\n        mimeType,\n        base64_length: base64 ? base64.length : 0,\n        prompt_source: promptOverrides.extract_system\n          ? 'prompt_overrides.extract_system'\n          : (webhookBody.extract_system_prompt ? 'extract_system_prompt' : 'default')\n      }\n    },\n    binary: item.binary\n  });\n}\n\nreturn out;\n"
