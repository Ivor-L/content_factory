    {
      "parameters": {
        "jsCode": "function getAllText(root) {\n  const r = Array.isArray(root) ? root[0] : root;\n  const parts = r?.candidates?.[0]?.content?.parts || [];\n  return parts.map(p => p?.text || '').join('\\n').trim();\n}\n\nfunction stripCodeFence(text) {\n  return String(text || '')\n    .replace(/^```json\\s*/i, '')\n    .replace(/^```\\s*/i, '')\n    .replace(/\\s*```$/i, '')\n    .trim();\n}\n\nfunction tryParseJsonWithFixes(text) {\n  const errs = [];\n  try {\n    return { obj: JSON.parse(text), fixedText: text, errs };\n  } catch (e) {\n    errs.push('direct JSON.parse failed: ' + e.message);\n  }\n  let fixed = text;\n  fixed = fixed.replace(\n    /(\\\"time_range\\\"\\s*:\\s*)([^\\\"\\s][^,\\n}]*)/g,\n    (m, p1, p2) => {\n      const cleaned = String(p2).trim().replace(/^\\\"+|\\\"+$/g, '');\n      return `${p1}\\\"${cleaned}\\\"`;\n    }\n  );\n  fixed = fixed.replace(/,\\s*([}\\]])/g, '$1');\n  try {\n    return { obj: JSON.parse(fixed), fixedText: fixed, errs };\n  } catch (e) {\n    errs.push('fixed JSON.parse failed: ' + e.message);\n  }\n  return { obj: null, fixedText: fixed, errs };\n}\n\nconst items = $input.all();\nconst out = [];\n\nfor (const item of items) {\n  const original = item.json || {};\n\n  const result = {\n    ...original,\n    parse_ok: false,\n    analysis: null,\n    breakdown: null,\n    final_status: 'failed',\n    final_error: null,\n    should_deduct: false,\n    _raw_text: null,\n    _fixed_text: null,\n    errors: []\n  };\n\n  if (original.error) {\n    result.final_error = `Gemini调用失败: ${original.error.message || JSON.stringify(original.error)}`;\n    result.errors = [result.final_error];\n    out.push({ json: result });\n    continue;\n  }\n\n  const text = stripCodeFence(getAllText(original));\n  result._raw_text = text;\n\n  if (!text) {\n    result.final_error = 'Gemini返回为空，未找到 candidates[0].content.parts[].text';\n    result.errors = [result.final_error];\n    out.push({ json: result });\n    continue;\n  }\n\n  const parsed = tryParseJsonWithFixes(text);\n  result._fixed_text = parsed.fixedText;\n\n  if (!parsed.obj) {\n    result.final_error = parsed.errs.join(' | ') || 'JSON解析失败';\n    result.errors = parsed.errs;\n    out.push({ json: result });\n    continue;\n  }\n\n  // Extract blueprint (visual analysis: meta + scene_breakdown)\n  const { breakdown: bdRaw, ...blueprintData } = parsed.obj;\n  result.parse_ok = true;\n  result.analysis = blueprintData; // meta + scene_breakdown -> saved to blueprint column\n  result.breakdown = bdRaw || { description: '', intro: '', body: '', conclusion: '' }; // -> saved to breakdown column\n  result.final_status = 'completed';\n  result.final_error = null;\n  result.should_deduct = true;\n  result.errors = [];\n\n  out.push({ json: result });\n}\n\nreturn out;\n"
      },
