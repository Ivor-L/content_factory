        "mode": "runOnceForEachItem",
        "jsCode": "const body = $json.body || $json;\n\nconst safe = (v) => String(v ?? '').trim();\n\nconst segmentId = safe(body.segment_id);\nconst taskId = safe(body.task_id);\nconst prompt = safe(body.prompt);\nconst firstFrameUrl = safe(body.first_frame_url);\nconst duration = Number(body.duration) || 8;\nconst model = safe(body.model) || 'veo3-fast';\nconst aspectRatio = safe(body.aspect_ratio) || '9:16';\nconst callbackUrl = safe(body.callback_url);\nconst apiKey = safe(body.api_key);\nconst adminToken = safe(body.admin_token);\nconst workflowId = safe(body.workflow_id) || 'flow_storyboard_veo3';\n\nif (!segmentId) throw new Error('segment_id is required');\nif (!prompt) throw new Error('prompt is required');\nif (!callbackUrl) throw new Error('callback_url is required');\nif (!apiKey) throw new Error('api_key is required');\n\n// images will be injected as base64 by the next node\nconst requestBody = {\n  model,\n  prompt,\n  enhance_prompt: true,\n  enable_upsample: true,\n  aspect_ratio: aspectRatio,\n};\n\nreturn {\n  json: {\n    segment_id: segmentId,\n    task_id: taskId,\n    callback_url: callbackUrl,\n    api_key: apiKey,\n    admin_token: adminToken,\n    workflow_id: workflowId,\n    firstFrameUrl,\n    requestBody,\n  }\n};"
      },
