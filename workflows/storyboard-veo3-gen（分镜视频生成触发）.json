      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const res = $json || {};\nconst prev = $('准备Veo3参数').first().json;\n\nconst id = res.id || res.data?.id;\nconst status = res.status || res.data?.status || 'pending';\n\nif (!id) {\n  throw new Error('Veo3 create 失败，未返回 task id: ' + JSON.stringify(res).slice(0, 300));\n}\n\nreturn {\n  json: {\n    veo3_task_id: id,\n    veo3_status: status,\n    segment_id: prev.segment_id,\n    task_id: prev.task_id,\n    callback_url: prev.callback_url,\n    api_key: prev.api_key,\n    admin_token: prev.admin_token,\n    workflow_id: prev.workflow_id,\n  }\n};"
