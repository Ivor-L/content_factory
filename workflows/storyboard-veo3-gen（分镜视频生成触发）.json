      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item;\nconst requestBody = { ...item.json.requestBody };\n\nif (item.binary && item.binary.data && item.binary.data.data) {\n  const b = item.binary.data;\n  const mimeType = b.mimeType || 'image/jpeg';\n  const base64 = b.data;\n  requestBody.images = [`data:${mimeType};base64,${base64}`];\n}\n\nreturn {\n  json: {\n    ...item.json,\n    requestBody,\n  }\n};"
      }
    }
