{
  "manifest_version": 3,
  "name": "NexTide 助手 v1.0.0",
  "version": "1.0.0",
  "description": "NexTide 助手是专为内容创作者设计的浏览器伴侣，帮助你在浏览小红书时快速采集并同步内容到内容工厂。",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://xiaohongshu.com/*",
    "*://*.xiaohongshu.com/*",
    "*://tiktok.com/*",
    "*://*.tiktok.com/*",
    "*://instagram.com/*",
    "*://*.instagram.com/*",
    "*://*/api/*",
    "http://localhost:*/*"
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "NexTide 助手 v1.0.0",
    "default_icon": "images/icon-48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://xiaohongshu.com/*",
        "*://*.xiaohongshu.com/*",
        "*://creator.xiaohongshu.com/*",
        "*://tiktok.com/*",
        "*://*.tiktok.com/*",
        "*://instagram.com/*",
        "*://*.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "style.css",
        "images/*.png"
      ],
      "matches": [
        "*://xiaohongshu.com/*",
        "*://*.xiaohongshu.com/*",
        "*://tiktok.com/*",
        "*://*.tiktok.com/*",
        "*://instagram.com/*",
        "*://*.instagram.com/*"
      ]
    }
  ]
}
