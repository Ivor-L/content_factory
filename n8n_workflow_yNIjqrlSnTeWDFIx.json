    },
    {
      "parameters": {
        "jsCode": "// n8n Code node: build Yunwu Gemini generateContent body for \u4ea7\u54c1\u8425\u9500DNA\n// \u2705 \u6570\u636e\u6765\u6e90\uff1aWebhook\uff08$json.body \u6216 $json\uff09\n// \u2705 \u6709\u56fe\uff1a\u4f18\u5148\u7528\u4e0a\u6e38\u201c\u4e0b\u8f7d\u56fe\u7247\u201d\u7684 binary -> inlineData(base64)\n// \u2705 \u65e0\u56fe\uff1a\u7eaf\u6587\u672c\u4e5f\u80fd\u5206\u6790\uff08\u4e0d throw\uff09\n\n// ---------- helpers ----------\nfunction pickText(v) {\n  if (v == null) return '';\n  if (typeof v === 'string' || typeof v === 'number') return String(v);\n\n  if (Array.isArray(v)) {\n    return v\n      .map(x => {\n        if (x == null) return '';\n        if (typeof x === 'string' || typeof x === 'number') return String(x);\n        if (typeof x === 'object') return String(x.text ?? x.value ?? x.name ?? x.url ?? x.link ?? '');\n        return '';\n      })\n      .filter(Boolean)\n      .join('\\n');\n  }\n\n  if (typeof v === 'object') return String(v.text ?? v.value ?? v.name ?? v.url ?? v.link ?? '');\n  return String(v);\n}\n\nfunction getField(obj, keyCandidates) {\n  for (const k of keyCandidates) {\n    if (obj && Object.prototype.hasOwnProperty.call(obj, k)) return pickText(obj[k]);\n  }\n  return '';\n}\n\nfunction pickBinaryKey(bin) {\n  if (!bin || typeof bin !== 'object') return '';\n  if (bin.image) return 'image';\n  if (bin.data) return 'data';\n  const keys = Object.keys(bin);\n  return keys.length ? keys[0] : '';\n}\n\nasync function getBase64FromBinary(itemIndex, binaryKey) {\n  const bin = $input.all()[itemIndex].binary?.[binaryKey];\n  if (!bin) return { base64: '', mimeType: '' };\n\n  const mimeType = bin.mimeType || 'image/jpeg';\n\n  // \u60c5\u51b5A\uff1abinary \u81ea\u5e26 base64\n  if (bin.data && typeof bin.data === 'string' && bin.data.length > 50) {\n    return { base64: bin.data, mimeType };\n  }\n\n  // \u60c5\u51b5B\uff1afilesystem \u6a21\u5f0f\uff1a\u8bfb buffer\n  if (!this?.helpers?.getBinaryDataBuffer) {\n    return { base64: '', mimeType };\n  }\n  const buf = await this.helpers.getBinaryDataBuffer(itemIndex, binaryKey);\n  return { base64: buf.toString('base64'), mimeType };\n}\n\n// ---------- read webhook body ----------\nconst root = $json || {};\nconst body = (root.body && typeof root.body === 'object') ? root.body : root;\n\n// \u517c\u5bb9\u5b57\u6bb5\u540d\uff08\u4f60\u524d\u7aef\u73b0\u5728\u4f20\u7684\u662f product_name / api_key / workflow_id\uff09\nconst productId   = getField(body, ['product_id', 'productId', 'id']);\nconst imageUrl    = getField(body, ['image_url', 'imageUrl', 'url']);\nconst apiKey      = getField(body, ['api_key', 'apiKey']);\nconst workflowId  = getField(body, ['workflow_id', 'workflowId']);\n\n// \u201c\u4ea7\u54c1\u540d\u79f0/\u5356\u70b9/\u63cf\u8ff0\u201d\u5b57\u6bb5\uff1a\u517c\u5bb9\u4f60\u65e7\u98de\u4e66\u5b57\u6bb5\u540d + \u4f60\u65b0\u524d\u7aef\u5b57\u6bb5\u540d\nconst productName = getField(body, ['product_name','productName','\u4ea7\u54c1\u540d\u79f0', '\u4ea7\u54c1\u540d', '\u5546\u54c1\u540d\u79f0', '\u5546\u54c1\u540d']);\nconst sellingPts  = getField(body, ['selling_points','sellingPoints','\u4ea7\u54c1\u5356\u70b9\uff08\u9009\u586b\uff09', '\u6838\u5fc3\u5356\u70b9', '\u5356\u70b9', '\u4ea7\u54c1\u4eae\u70b9']);\nconst extraDesc   = getField(body, ['extra_desc','extraDesc','\u4ea7\u54c1\u63cf\u8ff0', '\u5546\u54c1\u63cf\u8ff0', '\u8865\u5145\u63cf\u8ff0', '\u63cf\u8ff0']);\n\n// ---------- prompt ----------\nconst PROMPT_TEXT = `# Role\n\u4f60\u662f\u4e00\u4f4d\u8d44\u6df1\u7684**\u7535\u5546\u9009\u54c1\u7ecf\u7406\u4e0e\u8425\u9500\u7b56\u5212\u4e13\u5bb6**\u3002\u64c5\u957f\u901a\u8fc7\u4e00\u5f20\u4ea7\u54c1\u56fe\u7247\uff0c\u53cd\u63a8\u5176\u6838\u5fc3\u5356\u70b9\u3001\u76ee\u6807\u4eba\u7fa4\u548c\u89c6\u89c9\u7279\u5f81\u3002\n\n# Task\n\u5206\u6790\u7528\u6237\u4e0a\u4f20\u7684\u4ea7\u54c1\u56fe\u7247\uff08\u6216\u63cf\u8ff0\uff09\uff0c\u8f93\u51fa\u4e00\u4efd**\u201c\u4ea7\u54c1\u8425\u9500DNA\u62a5\u544a\u201d**\u3002\u8fd9\u4efd\u62a5\u544a\u5c06\u7528\u4e8e\u6307\u5bfc\u540e\u7eed\u7684\u89c6\u9891\u811a\u672c\u751f\u6210\u3002\n\n# Analysis Logic\n1) \u89c6\u89c9\u5916\u89c2\uff1a\u989c\u8272\u3001\u6750\u8d28\u3001\u5f62\u72b6\u3001\u8d28\u611f\uff08\u8ba9\u89c6\u9891\u751f\u6210AI\u77e5\u9053\u201c\u4ea7\u54c1\u957f\u4ec0\u4e48\u6837\u201d\uff09\n2) \u6838\u5fc3\u5356\u70b9\uff1a\u529f\u80fd\u6027\u5356\u70b9 + \u4f53\u9a8c\u6027\u5356\u70b9\uff0c\u5e76\u7ed9\u51fa\u53ef\u89c6\u5316\u8bc1\u660e\u65b9\u5f0f\n3) \u4f7f\u7528\u573a\u666f\u4e0e\u4eba\u7fa4\uff1a\u8c01\u5728\u7528\u3001\u5728\u54ea\u7528\n\n# Output (STRICT JSON ONLY)\n{\n  \"product_name\": \"\u57fa\u4e8e\u56fe\u7247\u63a8\u65ad\u7684\u4ea7\u54c1\u540d\u79f0\",\n  \"visual_description\": \"\u8be6\u7ec6\u89c6\u89c9\u63cf\u8ff0\uff08\u7ed9Sora/\u89c6\u9891\u63d0\u793a\u8bcd\u7528\uff09\",\n  \"marketing_profile\": {\n    \"target_audience_vibe\": \"\u76ee\u6807\u7528\u6237\u5f62\u8c61\",\n    \"ideal_environment\": \"\u6700\u4f73\u573a\u666f\",\n    \"core_selling_points\": [\n      {\n        \"type\": \"Physical\",\n        \"description\": \"\u7269\u7406\u7279\u6027\u5356\u70b9\",\n        \"visual_proof\": \"\u5982\u4f55\u7528\u753b\u9762\u8bc1\u660e\"\n      },\n      {\n        \"type\": \"Emotional\",\n        \"description\": \"\u60c5\u611f/\u4f53\u9a8c\u5356\u70b9\",\n        \"visual_proof\": \"\u5982\u4f55\u7528\u753b\u9762\u8bc1\u660e\"\n      }\n    ]\n  }\n}`;\n\nconst userSupplement = [\n  `\u4ea7\u54c1\u540d\u79f0\uff1a${productName || '\u672a\u63d0\u4f9b'}`,\n  `\u4ea7\u54c1\u5356\u70b9\uff1a${sellingPts || '\u672a\u63d0\u4f9b'}`,\n  `\u4ea7\u54c1\u63cf\u8ff0\uff1a${extraDesc || '\u672a\u63d0\u4f9b'}`,\n].join('\\n');\n\nconst userText = `${PROMPT_TEXT}\\n\\n${userSupplement}\\n\\n\u53ea\u8f93\u51fa JSON\uff0c\u4e0d\u8981 markdown\uff0c\u4e0d\u8981\u591a\u4f59\u6587\u672c\u3002`;\n\n// ---------- build gemini_body (supports batch items) ----------\nconst items = $input.all();\nconst out = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  const bin = item.binary || {};\n  const binaryKey = pickBinaryKey(bin);\n\n  let imagePart = null;\n  if (binaryKey) {\n    const { base64, mimeType } = await getBase64FromBinary.call(this, i, binaryKey);\n    if (base64) {\n      imagePart = {\n        inlineData: { mimeType, data: base64 }\n      };\n    }\n  }\n\n  const parts = [{ text: userText }];\n  if (imagePart) parts.push(imagePart);\n\n  const gemini_body = {\n    systemInstruction: {\n      parts: [{ text: 'Return STRICT JSON only. No markdown. No extra text.' }]\n    },\n    contents: [\n      { role: 'user', parts }\n    ],\n    generationConfig: {\n      responseMimeType: 'application/json',\n      temperature: 0.2\n    }\n  };\n\n  out.push({\n    json: {\n      ...item.json,\n      // \u628a\u4f60\u540e\u7eed\u8282\u70b9\u9700\u8981\u7684\u5b57\u6bb5\u4e5f\u4e00\u8d77\u900f\u4f20\uff08\u5173\u952e\uff09\n      product_id: productId,\n      image_url: imageUrl,\n      api_key: apiKey,\n      workflow_id: workflowId,\n\n      gemini_body,\n\n      _debug_webhook_fields: {\n        productId: productId || null,\n        imageUrl: imageUrl || null,\n        productName: productName || null,\n        sellingPts: sellingPts || null,\n        apiKey: apiKey ? '***' : null,\n        workflowId: workflowId || null,\n      },\n      _debug_image_attached: !!imagePart\n    },\n    binary: item.binary\n  });\n}\n\nreturn out;"
      },
