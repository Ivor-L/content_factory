    {
      "parameters": {
        "jsCode": "// \u6e05\u6d17\u5356\u70b9\u6570\u636e\uff1a\u89e3\u6790 Gemini \u8fd4\u56de + \u8865\u56de Webhook \u7684 product_id/api_key/workflow_id\n// \u8f93\u51fa\u7ed9 Supabase\uff1aproduct_id + selling_points(jsonb) + selling_points_text(string)\n\nconst input = $input.first()?.json || {};\n\n// 1) \u89e3\u6790 Gemini \u54cd\u5e94\uff08\u517c\u5bb9 body / data \u662f\u5b57\u7b26\u4e32\u7684\u60c5\u51b5\uff09\nlet resp = input.body ?? input;\n\nif (typeof resp === \"string\") {\n  try { resp = JSON.parse(resp); } catch (e) {}\n}\nif (typeof input.data === \"string\") {\n  try { resp = JSON.parse(input.data); } catch (e) {}\n}\n\n// 2) \u63d0\u53d6 Gemini \u6587\u672c\nconst parts = resp?.candidates?.[0]?.content?.parts;\nif (!Array.isArray(parts) || parts.length === 0) {\n  throw new Error(\"Gemini \u8fd4\u56de\u7f3a\u5c11 candidates[0].content.parts\");\n}\n\nlet text = parts.map(p => p?.text || \"\").join(\"\\n\").trim();\nif (!text) throw new Error(\"Gemini parts.text \u4e3a\u7a7a\");\n\n// \u53bb\u6389 ```json ``` \u5305\u88f9\ntext = text.replace(/^```json\\s*/i, \"\").replace(/^```\\s*/i, \"\");\ntext = text.replace(/\\s*```$/i, \"\").trim();\n\n// 3) JSON.parse \u6210 product_dna\nlet product_dna;\ntry {\n  product_dna = JSON.parse(text);\n} catch (e) {\n  const head = text.slice(0, 300);\n  const tail = text.slice(-300);\n  throw new Error(`product_dna JSON.parse \u5931\u8d25\uff1a${e.message}\\n---HEAD---\\n${head}\\n---TAIL---\\n${tail}`);\n}\n\n// 4) \u2705 \u4ece Webhook \u8282\u70b9\u8865\u56de\u4e0a\u4e0b\u6587\u5b57\u6bb5\uff08\u4e0d\u8981\u6307\u671b\u4e2d\u95f4 HTTP \u8282\u70b9\u4e00\u76f4\u4fdd\u7559\uff09\nconst wh = $(\"Webhook\").first().json || {};\nconst whBody = (wh.body && typeof wh.body === \"object\") ? wh.body : wh;\n\nconst product_id = whBody.product_id ?? null;\nconst api_key = whBody.api_key ?? null;\nconst workflow_id = whBody.workflow_id ?? null;\n\n// 5) \u7ed9 Supabase \u7684\u5199\u56de\u5b57\u6bb5\nconst selling_points = product_dna; // jsonb\n\nfunction safe(s) {\n  return String(s ?? \"\").trim();\n}\n\nconst name = safe(product_dna?.product_name);\nconst visual = safe(product_dna?.visual_description);\n\nconst mp = product_dna?.marketing_profile || {};\nconst audience = safe(mp?.target_audience_vibe);\nconst env = safe(mp?.ideal_environment);\n\nconst points = Array.isArray(mp?.core_selling_points) ? mp.core_selling_points : [];\n\n// \u751f\u6210 Markdown \u62a5\u544a\nlet md = \"\";\nif (name) md += `# ${name}\\n\\n`;\nif (visual) md += `## \u89c6\u89c9\u63cf\u8ff0\\n${visual}\\n\\n`;\n\nif (audience) md += `**\u76ee\u6807\u53d7\u4f17**: ${audience}\\n`;\nif (env) md += `**\u9002\u7528\u573a\u666f**: ${env}\\n\\n`;\n\nif (points.length > 0) {\n  md += `## \u6838\u5fc3\u5356\u70b9\\n`;\n  points.forEach(p => {\n    const type = safe(p.type || '\u5356\u70b9');\n    const desc = safe(p.description);\n    const proof = safe(p.visual_proof);\n    \n    md += `- **${type}**: ${desc}\\n`;\n    if (proof) md += `  > *\u753b\u9762*: ${proof}\\n`;\n  });\n  md += `\\n`;\n}\n\n// 6) \u8f93\u51fa\nreturn {\n  json: {\n    id: product_id, \n    product_id,\n    api_key,\n    workflow_id,\n    \n    // \u6570\u636e\u8f7d\u8377\n    selling_points,\n    selling_points_text: md || visual, // \u4f18\u5148\u7528 Markdown\n    \n    // \u539f\u59cb\u54cd\u5e94\u5907\u4efd\n    gemini_raw: resp\n  }\n};"
      },
