# 1. 数据库连接（云端 Supabase Postgres）
# 替换 <project-ref> 和 <database-password> 为 Supabase Dashboard 上的值。
DATABASE_URL="postgresql://postgres.<project-ref>:<database-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
PGSSLMODE=require
# 应急开关：仅在 db push 导致容器起不来时临时启用，恢复后应改回 0/1 默认值
SKIP_PRISMA_DB_PUSH=0
PRISMA_DB_PUSH_REQUIRED=1

# 2. Supabase API 配置（供前端使用）
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# ⚠️ 必填：没有此 key 服务器端无法上传文件到 Supabase Storage（头像、视频等上传会失败）
SUPABASE_SERVICE_ROLE_KEY=""
# 存储桶名称（默认 uploads，需在 Supabase Dashboard 中创建并设为公开）
NEXT_PUBLIC_SUPABASE_BUCKET="uploads"

# 2.1 阿里云 OSS（可选，但配置后上传会优先走 OSS）
ALIYUN_OSS_REGION=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_OSS_PUBLIC_URL="" # 可选；未配置时会根据 bucket + region 自动推导
ALIYUN_OSS_INTERNAL="false"
MEDIA_CACHE_STORAGE="oss"

# 3. 云雾模型聚合 API（统一调用 GPT / Claude / Gemini / Sora 等）
CLOUD_API_KEY=""
CLOUD_API_BASE_URL="https://api.yunwu.example/v1"
CLOUD_DEFAULT_MODEL="gpt-4o-mini"
CLOUD_HISTORY_MODEL="gpt-4o-mini"
CLOUD_STORY_MODEL="gpt-4o-mini"
CLOUD_STYLE_MODEL="gpt-4o-mini"
CLOUD_WRITING_MODEL="gpt-4o-mini"
ASSET_HISTORY_MAX_TOKENS=1400
ASSET_STORY_MAX_TOKENS=1100
ASSET_STYLE_MAX_TOKENS=900

# 4. 队列 / Worker 配置（pg-boss）
QUEUE_DATABASE_URL="" # 默认留空则使用 DATABASE_URL
PG_BOSS_SCHEMA="pgboss"
ASSET_JOB_RETRY_LIMIT=3
ASSET_JOB_RETRY_DELAY=30
ASSET_HISTORY_CONCURRENCY=1
ASSET_STORY_CONCURRENCY=1
ASSET_STYLE_CONCURRENCY=1

# 5. N8N 自动化 Webhook（可选）
N8N_STORYBOARD_SCRIPT_WEBHOOK=""
N8N_IMAGE_GEN_WEBHOOK="https://hooks.atomx.top/webhook/storyboard-image-generate"
N8N_VIDEO_GEN_WEBHOOK="https://hooks.atomx.top/webhook/storyboard_video"
N8N_SOCIAL_SCRAPER_WEBHOOK="https://hooks.atomx.top/webhook/social_scrape"

# 6. Social Scraper（TikTok / Facebook / Instagram）
SOCIAL_SCRAPER_APIFY_TOKEN=""
SOCIAL_SCRAPER_WEBHOOK_SECRET=""

# 6.1 XHS Downloader（小程序爆款广场手动采集）
XHS_DOWNLOADER_BASE_URL=""
XHS_DOWNLOADER_COOKIE=""
XHS_DOWNLOADER_PROXY=""
# 6.2 小程序爆款数据中心（search_notes 分类采集）
HOT_SQUARE_XHS_API_BASE_URL="https://api.tikhub.io"
HOT_SQUARE_XHS_API_KEY=""

# 7. 小红书发布（扫码发布二维码）
REDNOTE_API_KEY=""
# 兼容别名（任选其一；deploy-safe 会统一写回 REDNOTE_API_KEY）
REDNOTE_QR_API_KEY=""
XHS_QR_PUBLISH_API_KEY=""
XHS_PUBLISH_API_KEY=""

# 8. 微信小程序登录（必填，否则 /api/auth/wechat/login 返回 503）
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
