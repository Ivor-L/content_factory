{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "earn.task.apply input",
  "type": "object",
  "properties": {
    "taskId": {
      "type": "string",
      "description": "淘金任务 ID。"
    },
    "platform": {
      "type": "string",
      "description": "接单平台。",
      "enum": [
        "xhs",
        "douyin"
      ]
    },
    "platformUid": {
      "type": "string",
      "description": "平台账号 UID；未知时可为空。"
    },
    "platformAccountName": {
      "type": "string",
      "description": "平台账号昵称。"
    },
    "taskMaterialId": {
      "type": "string",
      "description": "指定素材 ID；为空时系统自动分配。"
    }
  },
  "required": [
    "taskId",
    "platform"
  ],
  "additionalProperties": true
}