# Copy to .env.loadtest.local and fill real values. Do not commit .env.loadtest.local.
BASE_URL=https://atomx.top
LOGIN_EMAIL=
LOGIN_PASSWORD=
LOAD_TEST_ID=20260506-content-factory

# Optional tuning
READONLY_TARGET_VUS=100
WRITE_TARGET_VUS=100
AI_TARGET_VUS=10

# AI/n8n generation is disabled unless ENABLE_AI=1 is set explicitly.
ENABLE_AI=0

# k6 thresholds. Override only when an approved test plan changes.
HTTP_REQ_FAILED_RATE=0.01
READONLY_P95_MS=1200
WRITE_P95_MS=2500
AI_P95_MS=30000
