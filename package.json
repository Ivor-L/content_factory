{
  "name": "content-factory-web",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "prestart": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "lint:app": "eslint app components lib hooks",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "workers:assets": "tsx workers/assetProcessor.ts",
    "styles:previews": "tsx scripts/generate-style-previews.ts",
    "styles:thumbs": "tsx scripts/generate-system-style-thumbnails.ts",
    "layouts:previews": "tsx scripts/regenerate-layout-previews.ts",
    "build:extensions": "tsx scripts/build-extension-packages.ts",
    "build:nextide-cli": "tsc -p packages/nextide-cli/tsconfig.json",
    "capabilities:export": "tsx scripts/export-nextide-capabilities.ts",
    "skills:generate": "tsx scripts/generate-nextide-skills.ts",
    "fixtures:generate": "tsx scripts/generate-nextide-fixtures.ts",
    "skills:package": "npm run capabilities:export && npm run skills:generate && npm run fixtures:generate && tsx scripts/package-nextide-skills.ts",
    "build:nexapi:apifox": "tsx scripts/nexapi/build-apifox.ts",
    "backfill:media-cache": "tsx scripts/backfill-reference-media-cache.ts",
    "nextide": "node scripts/nextide-cli.mjs",
    "nextide:cli": "node packages/nextide-cli/dist/index.js",
    "nextide:link": "npm run build:nextide-cli && chmod +x packages/nextide-cli/dist/index.js && npm link ./packages/nextide-cli",
    "nextide:pack": "mkdir -p artifacts/cli && cd packages/nextide-cli && npm pack --pack-destination ../../artifacts/cli",
    "release:agent-runtime": "npm run nextide:pack && npm run skills:package && tsx scripts/package-nextide-agent-runtime.ts",
    "smoke:agent-runtime": "tsx scripts/smoke-nextide-agent-security.ts",
    "cleanup:agent-runs": "tsx scripts/cleanup-stale-agent-runs.ts",
    "loadtest:readonly": "k6 run tests/load/online-smoke-readonly.js",
    "loadtest:write": "k6 run tests/load/online-creative-task-write.js",
    "loadtest:ai": "k6 run tests/load/online-ai-generation.js",
    "loadtest:cleanup": "tsx scripts/loadtest-cleanup.ts",
    "loadtest:node": "node tests/load/node-loadtest.mjs",
    "loadtest:node-cleanup": "node tests/load/node-cleanup-loadtest.mjs"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.1",
    "@supabase/supabase-js": "^2.97.0",
    "@xyflow/react": "^12.10.1",
    "ali-oss": "^6.23.0",
    "alipay-sdk": "^4.14.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "formidable": "^3.5.4",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "markdown-it": "^14.1.1",
    "next": "latest",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "pg": "^8.19.0",
    "pg-boss": "^12.14.0",
    "react": "latest",
    "react-dom": "latest",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "latest",
    "@types/pg": "^8.18.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "playwright": "^1.58.2",
    "postcss": "^8.4.47",
    "prisma": "latest",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "latest"
  }
}
