# Database Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local Supabase exposure: host=127.0.0.1 port=54322 → supabase_db:5432
DATABASE_URL="postgresql://postgres.your-tenant-id:<password>@127.0.0.1:54322/postgres?sslmode=disable"
DIRECT_URL="postgresql://postgres.your-tenant-id:<password>@127.0.0.1:54322/postgres?sslmode=disable"
# Required because supabase_db listener has SSL disabled
PGSSLMODE=disable

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_BUCKET="uploads"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DEFAULT_USER_API_KEY=""

# N8N Webhooks
N8N_PRODUCT_ANALYSIS_WEBHOOK=""
N8N_SCRIPT_BREAKDOWN_WEBHOOK=""
N8N_REPLICATION_WEBHOOK=""
N8N_GENERATION_SELLING_POINTS_WEBHOOK=""
N8N_GENERATION_SCRIPT_WEBHOOK=""
N8N_STORYBOARD_GEN_WEBHOOK=""

# 爆款复刻 - 分镜控制模式
N8N_REPLICATION_SHOTS_SCENE_WEBHOOK="https://hooks.atom.top/webhook/SHOTS_SCENE"
N8N_REPLICATION_SHOTS_SCRIPT_WEBHOOK="https://hooks.atom.top/webhook/SHOTS_SCRIPT"
N8N_REPLICATION_SHOTS_FRAME_WEBHOOK="https://hooks.atom.top/webhook/SHOTS_FRAME"
N8N_REPLICATION_SHOTS_VIDEO_WEBHOOK="https://hooks.atom.top/webhook/SHOTS_VIDEO"
N8N_REPLICATION_SHOTS_VIDEO_CB_WEBHOOK="https://hooks.atom.top/webhook/SHOTS_VIDEO_CB"
