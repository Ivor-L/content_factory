# Database Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Hosted Supabase connection string (replace placeholders with your project ref + password)
DATABASE_URL="postgresql://postgres.<project-ref>:<database-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.<project-ref>:<database-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
PGSSLMODE=require

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_BUCKET="uploads"

# Aliyun OSS (media cache / uploads)
ALIYUN_OSS_REGION=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_OSS_PUBLIC_URL="https://oss-your-domain.com" # 可选；未配置时会根据 bucket + region 自动推导
ALIYUN_OSS_INTERNAL="false"
ALIYUN_OSS_TIMEOUT_MS="180000" # SDK request timeout, default 60s
ALIYUN_OSS_UPLOAD_TIMEOUT_MS="300000" # upload operation timeout, fallback to ALIYUN_OSS_TIMEOUT_MS
ALIYUN_OSS_MULTIPART_THRESHOLD_BYTES="20971520" # >=20MB use multipart upload
ALIYUN_OSS_MULTIPART_PART_SIZE_BYTES="5242880" # 5MB per part
ALIYUN_OSS_MULTIPART_PARALLEL="4" # concurrent parts for multipart upload

# Media cache
MEDIA_CACHE_STORAGE="oss" # options: oss | supabase | auto
MEDIA_CACHE_BUCKET="proxy-cache"
MEDIA_CACHE_PREFIX="viral-media"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DEFAULT_USER_API_KEY=""
SYSTEM_STYLE_OWNER_ID=""
SYSTEM_STYLE_ANALYSIS_API_KEY=""
REDNOTE_API_KEY=""

# Webhook Callback Auth
# Shared secret between App and n8n. App checks this on all /api/webhook/* endpoints.
# n8n "回调App" nodes must send: Header "x-admin-token" = {{ $('准备参数').first().json.adminToken }}
# Must also be set in Vercel Environment Variables for production.
ADMIN_TOKEN=""

# N8N Webhooks
N8N_PRODUCT_ANALYSIS_WEBHOOK=""
N8N_SCRIPT_BREAKDOWN_WEBHOOK=""
N8N_REPLICATION_WEBHOOK=""
N8N_GENERATION_SELLING_POINTS_WEBHOOK=""
N8N_GENERATION_SCRIPT_WEBHOOK=""
N8N_STORYBOARD_GEN_WEBHOOK=""
N8N_STORYBOARD_SCRIPT_WEBHOOK=""
N8N_STORYBOARD_BREAKDOWN_WEBHOOK="https://hooks.atomx.top/webhook/miniapp_viral_breakdown_grid"
N8N_IMAGE_GEN_WEBHOOK="https://hooks.atomx.top/webhook/storyboard-image-generate"
N8N_VIDEO_GEN_WEBHOOK="https://hooks.atomx.top/webhook/storyboard_video"

# Social Scraper (TikTok / Facebook / Instagram)
N8N_SOCIAL_SCRAPER_WEBHOOK="https://hooks.atomx.top/webhook/social_scrape"
SOCIAL_SCRAPER_APIFY_TOKEN=""
SOCIAL_SCRAPER_WEBHOOK_SECRET=""

# XHS Downloader (Miniapp hot-square collect)
XHS_DOWNLOADER_BASE_URL=""
XHS_DOWNLOADER_COOKIE=""
XHS_DOWNLOADER_PROXY=""
# Miniapp hot-square data center collect (search_notes)
HOT_SQUARE_XHS_API_BASE_URL="https://api.tikhub.io"
HOT_SQUARE_XHS_API_KEY=""

# 写作风格提炼
N8N_WRITING_STYLE_EXTRACT_WEBHOOK=""
N8N_WRITING_STYLE_EXTRACT_WORKFLOW_ID="flow_writing_style_extract"
N8N_WRITING_STYLE_EXTRACT_WORKFLOW_NAME="提取创作风格"
WRITING_STYLE_EXTRACT_CALLBACK_BASE_URL="http://localhost:3000"
WRITING_STYLE_EXTRACT_WEBHOOK_SECRET=""

# Canvas Independent Upstream (for canvas adapter)
# Option A: configure one base URL (default paths: /chat/completions, /images/generations, /videos, /videos/{taskId})
CANVAS_API_BASE_URL=""
# Option B: configure each endpoint explicitly (higher priority than CANVAS_API_BASE_URL)
CANVAS_CHAT_COMPLETIONS_URL=""
CANVAS_IMAGE_GENERATIONS_URL=""
CANVAS_VIDEO_GENERATIONS_URL=""
CANVAS_VIDEO_TASK_URL_TEMPLATE=""
# Optional path overrides when using CANVAS_API_BASE_URL
CANVAS_CHAT_COMPLETIONS_PATH=""
CANVAS_IMAGE_GENERATIONS_PATH=""
CANVAS_VIDEO_GENERATIONS_PATH=""
CANVAS_VIDEO_TASK_PATH=""
# Optional upstream auth for canvas adapter
CANVAS_UPSTREAM_BEARER_TOKEN=""
CANVAS_UPSTREAM_ADMIN_TOKEN=""
# Default Canvas API Key (used when user未绑定 API Key)
CANVAS_UPSTREAM_DEFAULT_API_KEY=""
# 可选：若积分扣除需使用不同的系统 API Key，可单独设置；留空则沿用上面的默认值
CANVAS_CREDITS_DEFAULT_API_KEY=""

# Optional pre-deduction config for canvas image/video generation
CANVAS_IMAGE_WORKFLOW_ID="flow_image_video_Veo"
CANVAS_IMAGE_WORKFLOW_NAME="Canvas Image Generation"
CANVAS_IMAGE_CREDIT_COST=""
CANVAS_VIDEO_WORKFLOW_ID="flow_video_Veo"
CANVAS_VIDEO_WORKFLOW_NAME="Canvas Video Generation"
CANVAS_VIDEO_CREDIT_COST=""

# Canvas video async poll register (optional)
CANVAS_VIDEO_POLL_REGISTER_URL="https://api.atomx.top/tools/veo/poll/async"
CANVAS_VIDEO_POLL_CALLBACK_BASE_URL=""
CANVAS_VIDEO_POLL_WEBHOOK_SECRET=""
